{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "extensionsToTreatAsEsm": [".ts"],
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.m?ts$": ["ts-jest", { "useESM": true }]
  }
}
